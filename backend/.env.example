# =============================================================================
# Talentin Backend — Environment Configuration Template
# =============================================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in all values below
# 3. NEVER commit .env to git (already in .gitignore)
# =============================================================================

# --- ENVIRONMENT ---
SEARCH_ENV=production

# --- QDRANT VECTOR DATABASE ---
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=profiles_hybrid
QDRANT_COLLECTION_DENSE=talent_profiles

# --- DUCKDB DATABASE ---
DUCKDB_PATH=/var/www/talentin/database/talent_search.duckdb

# --- EMBEDDING MODEL ---
# Must match model used to build Qdrant vectors
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2

# --- OPENAI (smart search query parsing) ---
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.1
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_RETRIES=3
OPENAI_DAILY_LIMIT_USD=10.0

# --- FEATURE FLAGS ---
ENABLE_OPENAI_PARSING=true
ENABLE_TEXT_PARSING=true
ENABLE_FACETED_FILTERS=true

# --- RATE LIMITING ---
RATE_LIMIT_RPM=100
RATE_LIMIT_BURST=20

# --- MULTI-TENANT ---
DEFAULT_CLIENT_ID=00

# --- INTEGRATION API (TypeScript Mediator Backend) ---
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# Pass as header:  X-Integration-Key: <value>
INTEGRATION_API_KEY=your-long-random-secret-here

# Per-client key map: { "<api-key>": "<client_id>" }
# Example: INTEGRATION_KEY_CLIENT_MAP={"key-abc123": "00"}
INTEGRATION_KEY_CLIENT_MAP={}

# Only needed if a browser calls the mediator directly (CORS)
MEDIATOR_ORIGIN=